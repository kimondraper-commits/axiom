generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PLANNER
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ProjectPhase {
  INITIATION
  PLANNING
  DESIGN
  REVIEW
  APPROVAL
  IMPLEMENTATION
  CLOSEOUT
}

enum MessageRole {
  user
  assistant
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          Role      @default(VIEWER)
  department    String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  projectMembers ProjectMember[]
  documents    Document[]
  comments     Comment[]
  chatSessions ChatSession[]
  dataImports  DataImport[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  status      ProjectStatus @default(PLANNING)
  phase       ProjectPhase  @default(INITIATION)
  city        String
  district    String?
  address     String?
  bboxWkt     String?
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lga               String?
  projectType       String?
  applicantName     String?
  applicantEmail    String?
  lodgementDate     DateTime?
  dwellings         Int?
  commercialGfa     Float?
  buildingHeight    Float?
  storeys           Int?
  carParking        Int?
  siteAreaHa        Float?
  constructionCostM Float?
  greenSpaceHa      Float?
  nswStatus         String?

  members          ProjectMember[]
  documents        Document[]
  comments         Comment[]
  chatSessions     ChatSession[]
  complianceItems  ComplianceItem[]
  milestones       TimelineMilestone[]
  stakeholders     ProjectStakeholder[]
  submissions      CommunitySubmission[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      Role     @default(VIEWER)
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Document {
  id           String   @id @default(cuid())
  projectId    String
  name         String
  s3Key        String
  fileType     String
  fileSize     Int?
  category     String?
  version      Int      @default(1)
  uploadedById String
  createdAt    DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])

  @@map("documents")
}

model Comment {
  id          String   @id @default(cuid())
  projectId   String
  parentId    String?
  body        String   @db.Text
  isPublic    Boolean  @default(false)
  isApproved  Boolean  @default(false)
  authorId    String?
  authorName  String?
  authorEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User?     @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@map("comments")
}

model MapLayer {
  id           String   @id @default(cuid())
  name         String
  description  String?
  layerType    String
  sourceConfig Json
  layerConfig  Json
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("map_layers")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?      @relation(fields: [projectId], references: [id])
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model ComplianceItem {
  id        String   @id @default(cuid())
  projectId String
  label     String
  checked   Boolean  @default(false)
  notes     String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("compliance_items")
}

model TimelineMilestone {
  id              String    @id @default(cuid())
  projectId       String
  name            String
  milestoneStatus String    @default("upcoming")
  dueDate         DateTime?
  completedDate   DateTime?
  notes           String?   @db.Text
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("timeline_milestones")
}

model ProjectStakeholder {
  id           String   @id @default(cuid())
  projectId    String
  name         String
  role         String
  email        String?
  phone        String?
  organisation String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_stakeholders")
}

model CommunitySubmission {
  id            String   @id @default(cuid())
  projectId     String
  submitterName String?
  dateReceived  DateTime @default(now())
  keyIssues     String?  @db.Text
  response      String?  @db.Text
  status        String   @default("pending")
  supporting    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("community_submissions")
}

model DataImport {
  id              String       @id @default(cuid())
  filename        String
  fileType        String
  rowCount        Int
  mappedFields    Json
  status          ImportStatus @default(COMPLETED)
  importedById    String
  projectsCreated Int          @default(0)
  projectsUpdated Int          @default(0)
  errorCount      Int          @default(0)
  errorLog        Json?
  calcSummary     Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  importedBy      User         @relation(fields: [importedById], references: [id])

  @@map("data_imports")
}
